---
import CascadeSection from 'src/components/shared/CascadeSection.astro';
import ParchmentCard from 'src/components/shared/ParchmentCard.astro';
import AlchemicalDivider from 'src/components/shared/AlchemicalDivider.astro';
import AlchemicalScatter from 'src/components/shared/AlchemicalScatter.astro';
import BookshelfBackground from 'src/components/shared/BookshelfBackground.astro';
import FlankingDecor from 'src/components/shared/FlankingDecor.astro';
import CobwebCorner from 'src/components/shared/CobwebCorner.astro';
import HangingBotanicals from 'src/components/shared/HangingBotanicals.astro';

const steps = [
  { number: 'I', title: 'The Scrying', description: 'Every elixir begins with listening. What stirs you? What memories rise at the scent of rain on stone, of oud smoke in a sanctuary, of jasmine at the witching hour? We divine before we distill.' },
  { number: 'II', title: 'Gathering the Prima Materia', description: 'Each lot of oud, each shipment of musk, each distillation of rose is judged alone — because nature abhors uniformity, and so do we.' },
  { number: 'III', title: 'The Conjunction', description: 'Blending is not arithmetic — it is conversation. The perfumer works in 50ml cauldrons, adjusting by the drop, guided by instinct and material memory.' },
  { number: 'IV', title: 'The Long Rest', description: 'Like a potion left to mature in the dark, our blends slumber for six weeks minimum — allowing the volatile humors to marry into a harmonious whole.' },
  { number: 'V', title: 'The Sealing & Sending', description: 'Each bottle filled by hand. Labeled by hand. Wrapped by hand. Before it leaves, the perfumer passes his nose over <span class="italic">every</span> batch — because someone across an ocean waits.' },
];

const tilts = ['left', 'right', 'left', 'right', 'left'] as const;
---

<section class="relative py-20 sm:py-28">
  <BookshelfBackground variant="full" opacity={0.08} seed={99} />
  <AlchemicalScatter density="medium" />
  <FlankingDecor />
  <HangingBotanicals side="left" seed={13} />
  <CobwebCorner position="top-right" />
  <div class="relative z-10 mx-auto max-w-5xl px-6">
    <div class="mb-14 text-center"><span class="font-display text-xs tracking-[0.2em] uppercase text-amber/60">The Art</span><h2 class="mt-4 text-parchment">Five Stages of<br/>Transmutation</h2><p class="mt-4 mx-auto max-w-xl text-sm leading-relaxed text-parchment-dim">From first scrying to final seal — the alchemist's path from raw matter to liquid soul.</p></div>
    <AlchemicalDivider variant="diamond" />
    <div class="space-y-6">
      {steps.map((step, i) => (
        <CascadeSection rotate={i % 2 === 0 ? 'left' : 'right'}>
          <ParchmentCard tilt={tilts[i]}>
            <div class="flex flex-col gap-4 sm:flex-row sm:gap-8 sm:items-start">
              <div class="shrink-0"><span class="font-display text-4xl text-amber/30 sm:text-5xl">{step.number}</span></div>
              <div><h3 class="font-display text-xl text-parchment">{step.title}</h3><p class="mt-2 text-sm leading-relaxed text-parchment-dim" set:html={step.description} /></div>
            </div>
          </ParchmentCard>
        </CascadeSection>
      ))}
    </div>
  </div>
</section>
