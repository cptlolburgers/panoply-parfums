---
import ingredients from 'src/data/ingredients.json';
import CascadeSection from 'src/components/shared/CascadeSection.astro';
import ParchmentCard from 'src/components/shared/ParchmentCard.astro';
import TextureOverlay from 'src/components/shared/TextureOverlay.astro';
import AlchemicalDivider from 'src/components/shared/AlchemicalDivider.astro';
import AlchemicalScatter from 'src/components/shared/AlchemicalScatter.astro';
import CobwebCorner from 'src/components/shared/CobwebCorner.astro';
import GlasswareCollection from 'src/components/shared/GlasswareCollection.astro';
import BookshelfBackground from 'src/components/shared/BookshelfBackground.astro';

const tilts = ['left', 'right', 'left', 'right'] as const;
---

<section class="relative py-20 sm:py-28">
  <TextureOverlay opacity={0.07} frequency={2.0} />
  <BookshelfBackground variant="full" opacity={0.08} seed={7} />
  <GlasswareCollection side="left" seed={10} />
  <GlasswareCollection side="right" seed={11} />
  <AlchemicalScatter density="dense" />
  <CobwebCorner position="top-left" />
  <div class="relative z-10 mx-auto max-w-6xl px-6">
    <div class="mb-14 text-center"><span class="font-display text-xs tracking-[0.2em] uppercase text-amber/60">The Gathering</span><h2 class="mt-4 text-parchment">Where the Prima<br/>Materia Comes From</h2><p class="mt-4 mx-auto max-w-xl text-sm leading-relaxed text-parchment-dim">Every ingredient carries a story — and that story must honor both earth and hand.</p></div>
    <AlchemicalDivider variant="line" />
    <div class="space-y-12">
      {ingredients.map((ingredient, i) => (
        <CascadeSection rotate={i % 2 === 0 ? 'left' : 'right'}>
          <div class={`flex flex-col gap-8 ${i % 2 === 1 ? 'md:flex-row-reverse' : 'md:flex-row'} md:items-start`}>
            <ParchmentCard tilt={tilts[i]} glow class="md:w-2/3"><div class="flex flex-col gap-4"><div class="flex items-center gap-3"><span class="text-2xl" aria-hidden="true">{ingredient.icon}</span><h3 class="font-display text-2xl text-amber">{ingredient.name}</h3></div><p class="text-sm leading-relaxed text-parchment-dim">{ingredient.description}</p></div></ParchmentCard>
            <div class="md:w-1/3 md:pt-10">
              <ParchmentCard tilt={i % 2 === 0 ? 'right' : 'left'} class="h-full"><div class="flex flex-col gap-3"><h4 class="font-display text-sm tracking-[0.1em] uppercase text-parchment">Sourcing Method</h4><p class="text-sm leading-relaxed text-parchment-dim">{ingredient.sourcing}</p><div class="mt-3 border-t border-amber/10 pt-3"><h4 class="font-display text-xs tracking-[0.1em] uppercase text-parchment-dim/60">Notes</h4><div class="mt-2 flex flex-wrap gap-1.5">{ingredient.notes.map(note => (<span class="rounded-full border border-amber/10 bg-amber/5 px-2.5 py-0.5 font-body text-[10px] tracking-wider text-parchment-dim/70 uppercase">{note}</span>))}</div></div></div></ParchmentCard>
            </div>
          </div>
        </CascadeSection>
      ))}
    </div>
  </div>
</section>
