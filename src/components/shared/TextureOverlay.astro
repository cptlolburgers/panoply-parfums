---
// Shared texture overlay — renders the CSS grain on a section-level element
export interface Props {
  opacity?: number;
  zIndex?: number;
  frequency?: number;
}

const { opacity = 0.06, zIndex = 1, frequency = 1.2 } = Astro.props;
---

<div
  class="pointer-events-none absolute inset-0"
  style={`opacity: ${opacity}; z-index: ${zIndex}; background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise${frequency}'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='${frequency}' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise${frequency})'/%3E%3C/svg%3E\")`}
  aria-hidden="true"
></div>
