---
// GlasswareCollection — varied alchemical glassware: beakers, flasks, alembics, retorts
// Seeded for variation per instance
export interface Props {
  seed?: number;
  side?: 'left' | 'right';
}

const { seed = 1, side = 'left' } = Astro.props;

// Deterministic pseudo-random based on seed
function rng(s: number) {
  let state = s;
  return () => { state = (state * 16807 + 0) % 2147483647; return state / 2147483647; };
}

const rand = rng(seed);
const pick = <T,>(arr: T[]): T => arr[Math.floor(rand() * arr.length)];

const glassColors = ['rgba(201,169,110,0.18)', 'rgba(180,200,190,0.14)', 'rgba(160,180,200,0.12)', 'rgba(180,150,130,0.15)'];
const liquidColors = ['rgba(201,169,110,0.25)', 'rgba(74,21,32,0.3)', 'rgba(107,112,92,0.25)', 'rgba(180,148,62,0.2)', 'rgba(50,15,23,0.35)'];

// Generate varied glassware pieces
const pieces: Array<{x: number; y: number; scale: number; type: string; }> = [];
const count = 4 + Math.floor(rand() * 4);
for (let i = 0; i < count; i++) {
  pieces.push({
    x: -10 + rand() * 80,
    y: 15 + rand() * 55,
    scale: 0.4 + rand() * 0.8,
    type: pick(['beaker', 'flask', 'round-flask', 'alembic', 'test-tube', 'jar']),
  });
}
---

<div
  class={`pointer-events-none absolute top-0 h-full w-64 overflow-hidden opacity-[0.35] ${side === 'left' ? 'left-0' : 'right-0'}`}
  aria-hidden="true"
>
  <svg width="100%" height="100%" viewBox="0 0 200 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id={`glass-${seed}`} x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color={pick(glassColors)} />
        <stop offset="50%" stop-color="rgba(255,255,255,0.08)" />
        <stop offset="100%" stop-color={pick(glassColors)} />
      </linearGradient>
    </defs>

    {/* Surface line */}
    <line x1="10" y1="580" x2="190" y2="580" stroke={pick(glassColors)} stroke-width="0.5" opacity="0.4" />
    <line x1="15" y1="582" x2="185" y2="582" stroke="#0d0a08" stroke-width="1.5" opacity="0.2" />

    {pieces.map((p, i) => (
      <g key={i} transform={`translate(${p.x + 20}, ${580 - p.y}) scale(${p.scale})`}>
        {p.type === 'beaker' && (
          <>
            <path d="M-12 0L-10 -45L-7 -50H7L10 -45L12 0Z" fill="none" stroke={pick(glassColors)} stroke-width="1.5" />
            <rect x="-11" y="-30" width="22" height="15" fill={pick(liquidColors)} rx="1" opacity="0.7" />
            <line x1="-8" y1="-10" x2="8" y2="-10" stroke={pick(glassColors)} stroke-width="0.5" opacity="0.4" />
            <line x1="-6" y1="-5" x2="6" y2="-5" stroke={pick(glassColors)} stroke-width="0.5" opacity="0.3" />
            {/* Spout */}
            <path d="M12 -3L17 -3L15 2" fill="none" stroke={pick(glassColors)} stroke-width="1" />
          </>
        )}
        {p.type === 'flask' && (
          <>
            <rect x="-5" y="-40" width="5" height="12" fill="none" stroke={pick(glassColors)} stroke-width="1.2" />
            <path d="M-16 -28L-5 -28L-5 -15Q-16 -5 -5 5Q5 -5 16 -15L16 -28L5 -28" fill="none" stroke={pick(glassColors)} stroke-width="1.3" />
            <ellipse cx="0" cy="0" rx="10" ry="8" fill={pick(liquidColors)} opacity="0.6" />
          </>
        )}
        {p.type === 'round-flask' && (
          <>
            <rect x="-4" y="-50" width="4" height="12" fill="none" stroke={pick(glassColors)} stroke-width="1" />
            <circle cx="0" cy="-20" r="18" fill="none" stroke={pick(glassColors)} stroke-width="1.3" />
            <ellipse cx="0" cy="-16" rx="12" ry="10" fill={pick(liquidColors)} opacity="0.55" />
            <path d="M5 -20L10 -25" stroke={pick(glassColors)} stroke-width="0.8" opacity="0.5" />
          </>
        )}
        {p.type === 'alembic' && (
          <>
            <path d="M-14 10L-10 -20Q0 -40 10 -20L14 10Q0 15 -14 10Z" fill="none" stroke={pick(glassColors)} stroke-width="1.2" />
            <ellipse cx="0" cy="5" rx="10" ry="6" fill={pick(liquidColors)} opacity="0.5" />
            {/* Condenser arm */}
            <path d="M10 -18L25 -22L25 15" fill="none" stroke={pick(glassColors)} stroke-width="0.9" />
            <circle cx="25" cy="15" r="3" fill="none" stroke={pick(glassColors)} stroke-width="0.7" />
            <circle cx="25" cy="15" r="1" fill={pick(liquidColors)} opacity="0.4" />
          </>
        )}
        {p.type === 'test-tube' && (
          <>
            <rect x="-4" y="-55" width="6" height="35" rx="3" fill="none" stroke={pick(glassColors)} stroke-width="1.2" />
            <rect x="-3" y="-20" width="4" height="8" rx="1" fill={pick(liquidColors)} opacity="0.6" />
            <line x1="-2" y1="-45" x2="3" y2="-45" stroke={pick(glassColors)} stroke-width="0.5" opacity="0.3" />
          </>
        )}
        {p.type === 'jar' && (
          <>
            <rect x="-3" y="-30" width="6" height="6" rx="1" fill="none" stroke={pick(glassColors)} stroke-width="1" />
            <rect x="-10" y="-24" width="20" height="24" rx="4" fill="none" stroke={pick(glassColors)} stroke-width="1.2" />
            <rect x="-7" y="-16" width="14" height="10" rx="2" fill={pick(liquidColors)} opacity="0.55" />
            {/* Cork/stopper */}
            <rect x="-4" y="-33" width="8" height="4" rx="1" fill="#6b705c" opacity="0.5" />
          </>
        )}
      </g>
    ))}
  </svg>
</div>
