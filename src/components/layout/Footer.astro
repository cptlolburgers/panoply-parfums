---
// Footer — Patreon link, social, newsletter, copyright
import siteConfig from 'src/data/site-config.json';
import GlowButton from 'src/components/shared/GlowButton.astro';
---

<footer class="relative border-t border-amber/10 bg-abyss">
  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid gap-12 md:grid-cols-3">

      <!-- Brand col -->
      <div class="flex flex-col gap-4">
        <a href="/" class="flex flex-col leading-none">
          <span class="font-display text-xl tracking-[0.08em] text-parchment">PANOPLY</span>
          <span class="font-body text-xs tracking-[0.25em] text-parchment-dim">PARFUMS</span>
        </a>
        <p class="max-w-xs text-sm leading-relaxed text-parchment-dim">
          Artisan fragrances crafted with intention. Sustainably sourced ingredients, alchemical blends, personalized guidance.
        </p>
      </div>

      <!-- Links col -->
      <div class="flex flex-col gap-4">
        <h4 class="font-display text-sm tracking-[0.12em] uppercase text-parchment">Navigate</h4>
        <div class="flex flex-col gap-2">
          <a href="/" class="text-sm text-parchment-dim transition-colors hover:text-amber">Home</a>
          <a href="/about/" class="text-sm text-parchment-dim transition-colors hover:text-amber">About & Mission</a>
          <a href="/consultation/" class="text-sm text-parchment-dim transition-colors hover:text-amber">Consultation & Contact</a>
        </div>
      </div>

      <!-- Community col -->
      <div class="flex flex-col gap-4">
        <h4 class="font-display text-sm tracking-[0.12em] uppercase text-parchment">Community</h4>
        <div class="flex items-center gap-4">
          <!-- Patreon -->
          <a href={siteConfig.patreonUrl} target="_blank" rel="noopener noreferrer" class="text-parchment-dim/40 transition-colors hover:text-amber" aria-label="Patreon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M14.82 2.41c3.96 0 7.18 3.24 7.18 7.21 0 3.96-3.22 7.18-7.18 7.18-3.97 0-7.21-3.22-7.21-7.18 0-3.97 3.24-7.21 7.21-7.21M2 21.6h3.5V2.41H2v19.19z"/></svg>
          </a>
          <!-- Instagram -->
          <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" class="text-parchment-dim/40 transition-colors hover:text-amber" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
          </a>
          <!-- TikTok -->
          <a href={siteConfig.social.tiktok} target="_blank" rel="noopener noreferrer" class="text-parchment-dim/40 transition-colors hover:text-amber" aria-label="TikTok">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.89a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 5.03-1.8v-3.55a6.35 6.35 0 0 0-5.03 2.16 6.34 6.34 0 0 0 4.14 10.83 6.35 6.35 0 0 0 6.35-6.35V8.63a8.2 8.2 0 0 0 4.8 1.52v-3.4a5 5 0 0 1-1.3-.06z"/></svg>
          </a>
          <!-- Facebook -->
          <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" class="text-parchment-dim/40 transition-colors hover:text-amber" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
        <GlowButton href={siteConfig.patreonUrl} variant="secondary" size="sm" class="mt-2 w-fit">
          Support on Patreon
        </GlowButton>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col gap-2 border-t border-amber/10 pt-8 sm:flex-row sm:justify-between">
      <p class="text-xs text-parchment-dim/60">
        &copy; {new Date().getFullYear()} Panoply Parfums. All rights reserved.
      </p>
      <p class="text-xs text-parchment-dim/40 italic">
        Alchemy in every bottle.
      </p>
    </div>
  </div>
</footer>
