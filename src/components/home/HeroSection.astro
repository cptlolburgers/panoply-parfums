---
import GlowButton from 'src/components/shared/GlowButton.astro';
import TextureOverlay from 'src/components/shared/TextureOverlay.astro';
import AlchemicalScatter from 'src/components/shared/AlchemicalScatter.astro';
import CobwebCorner from 'src/components/shared/CobwebCorner.astro';
import FlankingDecor from 'src/components/shared/FlankingDecor.astro';
import LabFog from 'src/components/shared/LabFog.astro';
import AlchemistCorner from 'src/components/shared/AlchemistCorner.astro';
import BookshelfBackground from 'src/components/shared/BookshelfBackground.astro';
---

<section class="relative flex min-h-[90vh] flex-col items-center justify-center overflow-hidden px-6 py-24 text-center">
  <TextureOverlay opacity={0.10} />
  <BookshelfBackground variant="full" opacity={0.09} seed={0} />
  <LabFog />
  <AlchemicalScatter density="extra-dense" />
  <FlankingDecor />
  <AlchemistCorner position="bottom-right" seed={7} />
  <CobwebCorner position="top-left" />
  <CobwebCorner position="bottom-right" />

  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute left-1/2 top-1/3 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-amber/3 blur-[120px]" />
    <div class="absolute bottom-1/4 right-1/3 h-64 w-64 rounded-full bg-burgundy/3 blur-[100px]" />
  </div>

  <div class="relative z-10 max-w-4xl">
    <div class="mb-8 inline-flex items-center gap-3 rounded-full border border-amber/20 bg-amber/5 px-5 py-2">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-amber/60 opacity-75" />
        <span class="relative inline-flex h-2 w-2 rounded-full bg-amber" />
      </span>
      <span class="font-display text-xs tracking-[0.15em] uppercase text-amber/80">New Elixir Brewing</span>
    </div>
    <h1 class="mb-6 leading-[1.05]"><span class="block text-parchment">Alchemy in</span><span class="bg-gradient-to-r from-amber via-amber-glow to-parchment bg-clip-text text-transparent">Every Bottle</span></h1>
    <p class="mx-auto mb-10 max-w-2xl font-body text-lg leading-relaxed text-parchment-dim">Panoply Parfums — singular fragrances from the world's most arcane ingredients. Ethically gathered deer musk. Wild-harvested oud. Ocean-gifted ambergris. Hand-plucked delicate florals. No two phials alike. No spirit unadorned.</p>
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <GlowButton href="/consultation/" variant="primary" size="lg">Seek Your Scent</GlowButton>
      <GlowButton href="/about/" variant="ghost" size="md">Study the Grimoire</GlowButton>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-float" aria-hidden="true">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-parchment-dim/40"><path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" /></svg>
  </div>
</section>
