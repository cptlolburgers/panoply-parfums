---
// IngredientShowcase — 4 ingredient cards (musk, oud, ambergris, florals)
import ingredients from 'src/data/ingredients.json';
import CascadeSection from 'src/components/shared/CascadeSection.astro';
import ParchmentCard from 'src/components/shared/ParchmentCard.astro';
import TextureOverlay from 'src/components/shared/TextureOverlay.astro';
import AlchemicalScatter from 'src/components/shared/AlchemicalScatter.astro';
import BookshelfBackground from 'src/components/shared/BookshelfBackground.astro';

// Different tilt per card
const tilts = ['left', 'right', 'left', 'right'] as const;
---

<section class="relative py-20 sm:py-28">
  <TextureOverlay opacity={0.07} />
  <BookshelfBackground variant="full" opacity={0.10} />
  <AlchemicalScatter density="dense" />

  <div class="relative z-10 mx-auto max-w-6xl px-6">
    <div class="mb-14 text-center">
      <span class="font-display text-xs tracking-[0.2em] uppercase text-amber/60">The Alchemist's Materials</span>
      <h2 class="mt-4 text-parchment">Rare Ingredients,<br/>Ethically Gathered</h2>
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      {ingredients.map((ingredient, i) => (
        <CascadeSection rotate={i % 2 === 0 ? 'left' : 'right'}>
          <ParchmentCard tilt={tilts[i]} glow>
            <div class="flex flex-col gap-4">
              <span class="text-3xl" aria-hidden="true">{ingredient.icon}</span>
              <h3 class="font-display text-xl text-amber">{ingredient.name}</h3>
              <p class="font-body text-xs italic tracking-wider text-parchment-dim/60">{ingredient.latin}</p>
              <p class="text-sm leading-relaxed text-parchment-dim">{ingredient.description}</p>

              <div class="mt-2 flex flex-wrap gap-1.5">
                {ingredient.notes.map(note => (
                  <span class="rounded-full border border-amber/10 bg-amber/5 px-2.5 py-0.5 font-body text-[10px] tracking-wider text-parchment-dim/70 uppercase">
                    {note}
                  </span>
                ))}
              </div>

              <div class="mt-3 border-t border-amber/10 pt-3">
                <p class="font-body text-xs leading-relaxed text-parchment-dim/50 italic">
                  <span class="text-amber/50">Sourcing: </span>{ingredient.sourcing}
                </p>
              </div>
            </div>
          </ParchmentCard>
        </CascadeSection>
      ))}
    </div>
  </div>
</section>
