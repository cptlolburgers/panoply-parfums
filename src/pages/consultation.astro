---
import MainLayout from 'src/layouts/MainLayout.astro';
import Header from 'src/components/layout/Header.astro';
import Footer from 'src/components/layout/Footer.astro';
import ParchmentCard from 'src/components/shared/ParchmentCard.astro';
import AlchemicalDivider from 'src/components/shared/AlchemicalDivider.astro';
import TextureOverlay from 'src/components/shared/TextureOverlay.astro';
import AlchemicalScatter from 'src/components/shared/AlchemicalScatter.astro';
import FlankingDecor from 'src/components/shared/FlankingDecor.astro';
import CobwebCorner from 'src/components/shared/CobwebCorner.astro';
import LabFog from 'src/components/shared/LabFog.astro';
import GlasswareCollection from 'src/components/shared/GlasswareCollection.astro';
import HangingBotanicals from 'src/components/shared/HangingBotanicals.astro';
import BookshelfBackground from 'src/components/shared/BookshelfBackground.astro';
import ConsultationQuestionnaire from 'src/components/consultation/ConsultationQuestionnaire';
import ContactForm from 'src/components/consultation/ContactForm';
---

<MainLayout>
  <Header />
  <main>
    <section class="relative py-24 text-center overflow-hidden">
      <TextureOverlay opacity={0.09} />
      <BookshelfBackground variant="full" opacity={0.08} seed={33} />
      <LabFog />
      <AlchemicalScatter density="dense" />
      <FlankingDecor />
      <div class="relative z-10 mx-auto max-w-3xl px-6">
        <span class="font-display text-xs tracking-[0.2em] uppercase text-amber/60">Summon the Alchemist</span>
        <h1 class="mt-4 text-parchment">Seek Your<br/>Elixir</h1>
        <p class="mt-5 mx-auto max-w-lg text-sm leading-relaxed text-parchment-dim">Whether you seek your signature scent or have a general inquiry, I attend to every message personally. No scribes. No automata. One alchemist to one seeker.</p>
        <p class="mt-4 font-body text-xs text-parchment-dim/40 italic">Or pen your inquiry directly: <a href="mailto:varun@panoplyparfums.com" class="text-amber/60 underline underline-offset-2 transition-colors hover:text-amber">varun@panoplyparfums.com</a></p>
      </div>
    </section>

    <section class="relative py-12 sm:py-16">
      <FlankingDecor />
      <GlasswareCollection side="right" seed={20} />
      <CobwebCorner position="top-right" />
      <div class="relative z-10 mx-auto max-w-3xl px-6">
        <div class="mb-12 text-center"><span class="font-display text-xs tracking-[0.2em] uppercase text-amber/60">Charting Your Essence</span><h2 class="mt-4 text-parchment">Personalized Scent<br/>Consultation</h2><p class="mt-3 mx-auto max-w-md text-sm leading-relaxed text-parchment-dim">A few questions about your humors, your occasions, your curiosities — and I shall compose a recommendation delivered to your keep within 48 hours. Complimentary. No covenant required.</p></div>
        <ParchmentCard glow><ConsultationQuestionnaire client:load /></ParchmentCard>
      </div>
    </section>

    <AlchemicalDivider variant="orbital" />

    <section class="relative py-12 sm:py-16">
      <FlankingDecor />
      <HangingBotanicals side="left" seed={25} />
      <CobwebCorner position="bottom-left" />
      <div class="relative z-10 mx-auto max-w-2xl px-6">
        <div class="mb-12 text-center"><span class="font-display text-xs tracking-[0.2em] uppercase text-amber/60">Other Messages</span><h2 class="mt-4 text-parchment">Wholesale, Press,<br/>or General Inquiry</h2><p class="mt-3 mx-auto max-w-md text-sm leading-relaxed text-parchment-dim">Collaborations, bulk orders, or anything else on your mind.</p></div>
        <ParchmentCard><ContactForm client:load /></ParchmentCard>
      </div>
    </section>
  </main>
  <div class="py-8 sm:py-12" /><Footer />
</MainLayout>
